rue,"mahly_category_id":null,"spam_status":0,"branches":[],"branches_v2":[],"has_preorder_campaign":false,"preorder":[],"custom_url":"","unlimited_quantity":true,"features":{"availability_notify":{"email":true,"sms":true,"mobile":false,"whatsapp":false},"show_rating":false}},{"id":"1665411037","scope_id":null,"name":"تمويل التعليم من بنك التنمية الاجتماعية","description":"منتج تمويلي يهدف إلى تمكين الأفراد من مواصلة رحلتهم التعليمية بالتعاون مع جهات تعليمية معتمدة. يتم التقديم على المنتج إلكترونيًا بالكامل، دون الحاجة لزيارة فروع البنك. مميزات تمويل التعليم:&nbsp; تمويل يصل إلى 100 ألف ريال. فترة السداد تصل إلى 4 سنوات. يتم السداد بشكل شهري. بدون رسوم إدارية. يكون الإعفاء في حالة الوفاة لا سمح الله. شروط تمويل التعليم: ألا يقل عمر المتقدم عن 18 سنة. ألا يزيد الدخل الشهري للمتقدم عن 14,500 ريال. ان ترتبط الجهة التعليمية باتفاقية مع البنك. وجود قبول للمتقدم من الجهة التعليمية الشريكة. ان يقدم طالب التمويل ضمان مقابل التمويل. (ان لم تكن موظف حكومي او متقاعد حكومي، يلزم توفير كفيل موظف حكومي على رأس العمل). إذا كنت موظف ارامكوا او سابك تحتاج لكفيل. المتطلبات الأساسية: حساب بنكي شخصي، يمكنك طلب انشاء حساب بنكي من هنا. عنوان وطني، يمكنك طلب تسجيل عنوان وطني &nbsp; من هنا. وجود قبول للمتقدم من الجهة التعليمية الشريكة. رقم جوال باسم مقدم الطلب او احد الاقارب من الدرجة الأولى. شروط الكفيل: ان يكون موظف حكومي او شركة حكومية تساهم بها الدولة بأكثر من 50٪؜ من رأس المال ان لاتكون التزاماته المالية عاليه حسب سياسة بنك التنمية ان لا يكون كافل لقرضين آخرين دون الاقتراض، كافل لقرض ومستفيد من احد قروض بنك التنمية أن لاتوجد متأخرات على الكفيل أن لايتجاوز عمره اكثر من 55 سنه لاتقبل كفالة موظفي ارامكو او سابك. لا تقبل كفالة المتقاعد. ان لا يقل راتب الكفيل عن ٨٠٠٠ ربال. ملاحظات هامة: تم تحويل مبلغ القرض إلى الجهة التعليمية المعتمدة. يشترط لصرف الدفعات تقديم سجل أكاديمي يوضح دراسة الطالب للفصل الدراسي السابق.&nbsp; في حال عدم التقدم بطلب صرف الدفعة التالية خلال (9) أشهر، يتم الاكتفاء من القرض تلقائيًا. تم نقل الشروط من مصدرها، وقد تتحدث الشروط من مصدرها في اي وقت، يرجى التحقق من المصدر قبل اتمام الطلب. رحلتك في نُعين: اطلب الخدمة واكمل الدفع نتواصل معاك ونرسل لك كافة المتطلبات نرفع الطلب&nbsp; للمزيد من الاستفسارات يرجى التواصل على واتس اب&nbsp; 0533227672","url":"https://noeen.sa/ar/XzPPvdv","promotion_title":"جديد!!","subtitle":"","type":"service","status":"sale","weight":null,"calories":null,"sku":null,"rating":null,"quantity":null,"max_quantity":null,"is_taxable":false,"category":{"name":"الكل","url":null},"sale_channels_external":[],"original_image":"https://cdn.salla.sa/RlDV/lmSveBQLTzG88mvArToRryHdJqWfG0dbBjkSrQkT.png","image":{"url":"https://cdn.salla.sa/RlDV/lmSveBQLTzG88mvArToRryHdJqWfG0dbBjkSrQkT.png"},"brand":{"id":"578758586","url":null,"name":"بنك التنمية الاجتماعية"},"tags":[],"can_add_note":true,"can_upload_file":false,"is_on_sale":false,"is_hidded_quantity":false,"is_available":true,"is_donation":false,"is_out_of_stock":false,"is_require_shipping":false,"is_dynamic_pricing":false,"regular_price":150,"price":150,"sale_price":0,"starting_price":null,"currency":"SAR","mpn":null,"gtin":null,"discount_ends":null,"discount_starts":null,"has_options":false,"pinned":false,"mahly_category_id":null,"spam_status":0,"branches":[],"branches_v2":[],"has_preorder_campaign":false,"preorder":[],"custom_url":"","unlimited_quantity":true,"features":{"availability_notify":{"email":true,"sms":true,"mobile":false,"whatsapp":false},"show_rating":false}},{"id":"234977349","scope_id":null,"name":"التسجيل في تكافل دعم الطلاب","description":"‏الخدمة متاحة للمرشحين فقط من خلال المدرسة.","url":"https://noeen.sa/ar/WlwdxWz","promotion_title":"","subtitle":"","type":"product","status":"sale","weight":null,"calories":0,"sku":null,"rating":null,"quantity":null,"max_quantity":null,"is_taxable":true,"category":{"name":"الكل","url":null},"sale_channels_external":[],"original_image":null,"image":{"url":null},"brand":{"id":null,"url":null,"name":null},"tags":[],"can_add_note":true,"can_upload_file":false,"is_on_sale":false,"is_hidded_quantity":false,"is_available":true,
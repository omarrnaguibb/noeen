[{"id":"1143232232","scope_id":null,"name":"تسجيل الطلاب في رياض الاطفال","description":"خلّ تسجيل طفلك علينا 🎓✨ تبي تسجّل طفلك في الروضة بس مو عارف من وين تبدأ؟ أو ما عندك وقت تتابع الإجراءات؟ في نُعين نختصر عليك الطريق 👩🏻‍💻 نساعدك في تسجيل طفلك خطوة بخطوة، من اختيار الجهة المناسبة إلى تقديم الطلب بشكل صحيح، بدون لخبطة أو تضييع وقت. ✔️ نراجع متطلبات التسجيل ✔️ نجهّز البيانات بشكل دقيق ✔️ نقدّم لك على الروضات القريبة من مكان سكنك او اللي تحددها ✔️ نتابع معك إلى إتمام الطلب كل اللي عليك تطلب الخدمة… والباقي علينا 🤍 تنويه: التسجيل من قبل الاب، ويتاح للام بتوفر صك حضانة او مايثبت سجن الاب او مايعيق الطلب عبر الاب ويستغرق التسجيل من قبل الام وقت اطول يشترط وجود عنوان وطني صحيح لموقع السكن الروضة مستوى ثاني واول التسجيل يكون في المدارس الاهلية والعالمية فقط رحلتك في نُعين: اطلب الخدمة واكمل الدفع نتواصل معاك ونرسل لك كافة المتطلبات نرفع الطلب&nbsp; للمزيد من الاستفسارات يرجى التواصل على واتس اب 0533227672","url":"https://noeen.sa/ar/Olownw","promotion_title":"بدأ الحجز!","subtitle":"فترة التسجيل تبدأ من ٥ ابريل ٢٠٢٦م","type":"product","status":"sale","weight":null,"calories":0,"sku":null,"rating":null,"quantity":null,"max_quantity":null,"is_taxable":true,"category":{"name":"الكل","url":null},"sale_channels_external":[],"original_image":"https://cdn.salla.sa/RlDV/FSnAn2ypjwDRfHAy6ny88OZoF20vOGGOaOcJv3ql.jpg","image":{"url":"https://cdn.salla.sa/RlDV/FSnAn2ypjwDRfHAy6ny88OZoF20vOGGOaOcJv3ql.jpg"},"brand":{"id":null,"url":null,"name":null},"tags":[],"can_add_note":true,"can_upload_file":true,"is_on_sale":false,"is_hidded_quantity":false,"is_available":true,"is_donation":false,"is_out_of_stock":false,"is_require_shipping":false,"is_dynamic_pricing":false,"regular_price":40,"price":40,"sale_price":null,"starting_price":null,"currency":"SAR","mpn":null,"gtin":null,"discount_ends":null,"discount_starts":null,"has_options":false,"pinned":true,"mahly_category_id":null,"spam_status":0,"branches":[],"branches_v2":[],"has_preorder_campaign":false,"preorder":[],"custom_url":"","unlim